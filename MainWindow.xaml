<Window x:Class="SkinEditorNext.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LR2 Skin Editor Next"
        Height="860"
        Width="1320"
        MinHeight="680"
        MinWidth="1060"
        Background="#F3F4F6"
        PreviewKeyDown="Window_PreviewKeyDown">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="New Skin..." Click="NewSkin_Click"/>
                <Separator/>
                <MenuItem Header="Open..." Click="Open_Click"/>
                <MenuItem Header="Save" Click="Save_Click"/>
                <MenuItem Header="Save As..." Click="SaveAs_Click"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="Validate" Click="Validate_Click"/>
                <MenuItem Header="Refresh Preview" Click="RefreshPreview_Click"/>
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="0,0,0,1" Padding="10,8">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="New" Click="NewSkin_Click" MinWidth="76" Margin="0,0,6,0"/>
                        <Button Content="Open" Click="Open_Click" MinWidth="76" Margin="0,0,6,0"/>
                        <Button Content="Save" Click="Save_Click" MinWidth="76" Margin="0,0,6,0"/>
                        <Button Content="Save As" Click="SaveAs_Click" MinWidth="86" Margin="0,0,14,0"/>
                        <Button Content="Validate" Click="Validate_Click" MinWidth="86" Margin="0,0,6,0"/>
                        <Button Content="Preview" Click="RefreshPreview_Click" MinWidth="86"/>
                    </StackPanel>
                    <TextBlock x:Name="StatusText"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="#374151"/>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="430"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="0,0,1,0" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PanningMode="VerticalFirst">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="File" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock x:Name="FilePathText"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="#4B5563"/>
                            <TextBlock x:Name="EncodingText"
                                       Margin="0,4,0,12"
                                       Foreground="#6B7280"/>
                        </StackPanel>

                        <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0">
                                    <TextBlock Text="LR2 Theme Import" FontWeight="SemiBold" Foreground="#111827" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="Lr2ImportSummaryText"
                                               Foreground="#6B7280"
                                               TextAlignment="Right"/>
                                </DockPanel>
                                <ComboBox x:Name="Lr2ImportSkinBox"
                                          Grid.Row="1"
                                          DisplayMemberPath="DisplayName"
                                          Margin="0,8,0,8"/>
                                <UniformGrid Grid.Row="2" Columns="4">
                                    <ComboBox x:Name="ImportResolutionPresetBox"
                                              SelectedIndex="0"
                                              Margin="0,0,6,0">
                                        <ComboBoxItem Content="Keep" Tag="keep"/>
                                        <ComboBoxItem Content="SD 640x480" Tag="640,480"/>
                                        <ComboBoxItem Content="HD 1280x720" Tag="1280,720"/>
                                        <ComboBoxItem Content="FHD 1920x1080" Tag="1920,1080"/>
                                        <ComboBoxItem Content="4K 3840x2160" Tag="3840,2160"/>
                                    </ComboBox>
                                    <Button x:Name="ImportSkinButton"
                                            Content="Import"
                                            Click="ImportSkin_Click"
                                            Margin="0,0,6,0"/>
                                    <Button x:Name="ApplyImportResolutionButton"
                                            Content="Apply"
                                            Click="ApplyImportResolution_Click"
                                            Margin="0,0,6,0"/>
                                    <Button Content="Refresh"
                                            Click="RefreshLr2Import_Click"/>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="#RESOLUTION" FontWeight="SemiBold" Foreground="#111827"/>
                                <UniformGrid Grid.Row="1" Columns="2" Margin="0,8,0,8">
                                    <StackPanel Margin="0,0,6,0">
                                        <TextBlock Text="Width" Foreground="#4B5563"/>
                                        <TextBox x:Name="ResolutionWidthBox" MinHeight="28"/>
                                    </StackPanel>
                                    <StackPanel Margin="6,0,0,0">
                                        <TextBlock Text="Height" Foreground="#4B5563"/>
                                        <TextBox x:Name="ResolutionHeightBox" MinHeight="28"/>
                                    </StackPanel>
                                </UniformGrid>
                                <Button Grid.Row="2"
                                        Content="Apply Resolution"
                                        Click="ApplyResolution_Click"
                                        HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="112"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0">
                                    <TextBlock Text="Assets" FontWeight="SemiBold" Foreground="#111827" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="AssetsSummaryText"
                                               Foreground="#6B7280"
                                               TextAlignment="Right"/>
                                </DockPanel>
                                <ComboBox x:Name="ImageAssetBox"
                                          Grid.Row="1"
                                          DisplayMemberPath="DisplayName"
                                          SelectionChanged="ImageAssetBox_SelectionChanged"
                                          Margin="0,8,0,8"/>
                                <Border Grid.Row="2"
                                        Background="#F9FAFB"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <Image x:Name="AssetPreviewImage"
                                               Stretch="Uniform"
                                               SnapsToDevicePixels="True"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                        <TextBlock x:Name="AssetPreviewLabel"
                                                   Text="No asset selected"
                                                   Foreground="#6B7280"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"/>
                                    </Grid>
                                </Border>
                                <TextBlock x:Name="AssetPreviewInfoText"
                                           Grid.Row="3"
                                           Margin="0,0,0,8"
                                           Foreground="#4B5563"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Row="4"
                                        Content="Add Image..."
                                        Click="AddImage_Click"
                                        HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Create Object" FontWeight="SemiBold" Foreground="#111827"/>
                                <UniformGrid Grid.Row="1" Columns="2" Margin="0,8,0,8">
                                    <StackPanel Margin="0,0,6,0">
                                        <TextBlock Text="Kind" Foreground="#4B5563"/>
                                        <ComboBox x:Name="CreateKindBox" SelectedIndex="0">
                                            <ComboBoxItem Content="Image" Tag="image"/>
                                            <ComboBoxItem Content="Text" Tag="text"/>
                                            <ComboBoxItem Content="Number" Tag="number"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Margin="6,0,0,0">
                                        <TextBlock Text="Text Kind / Number Op1" Foreground="#4B5563"/>
                                        <TextBox x:Name="CreateValueBox" Text="11"/>
                                    </StackPanel>
                                </UniformGrid>
                                <UniformGrid Grid.Row="2" Columns="4">
                                    <StackPanel Margin="0,0,4,6">
                                        <TextBlock Text="X"/>
                                        <TextBox x:Name="CreateXBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="Y"/>
                                        <TextBox x:Name="CreateYBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="W"/>
                                        <TextBox x:Name="CreateWidthBox" Text="320"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,6">
                                        <TextBlock Text="H"/>
                                        <TextBox x:Name="CreateHeightBox" Text="180"/>
                                    </StackPanel>
                                </UniformGrid>
                                <UniformGrid Grid.Row="3" Columns="5">
                                    <StackPanel Margin="0,0,4,6">
                                        <TextBlock Text="Time"/>
                                        <TextBox x:Name="CreateTimeBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="Alpha"/>
                                        <TextBox x:Name="CreateAlphaBox" Text="255"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="R"/>
                                        <TextBox x:Name="CreateRedBox" Text="255"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="G"/>
                                        <TextBox x:Name="CreateGreenBox" Text="255"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,6">
                                        <TextBlock Text="B"/>
                                        <TextBox x:Name="CreateBlueBox" Text="255"/>
                                    </StackPanel>
                                </UniformGrid>
                                <UniformGrid Grid.Row="4" Columns="5">
                                    <StackPanel Margin="0,0,4,6">
                                        <TextBlock Text="Acc"/>
                                        <TextBox x:Name="CreateAccBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="Blend"/>
                                        <TextBox x:Name="CreateBlendBox" Text="1"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="Filter"/>
                                        <TextBox x:Name="CreateFilterBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="Angle"/>
                                        <TextBox x:Name="CreateAngleBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,6">
                                        <TextBlock Text="Center"/>
                                        <TextBox x:Name="CreateCenterBox" Text="0"/>
                                    </StackPanel>
                                </UniformGrid>
                                <UniformGrid Grid.Row="5" Columns="7">
                                    <StackPanel Margin="0,0,4,8">
                                        <TextBlock Text="Loop"/>
                                        <TextBox x:Name="CreateLoopBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,8">
                                        <TextBlock Text="Timer"/>
                                        <TextBox x:Name="CreateTimerBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,8">
                                        <TextBlock Text="Op1"/>
                                        <TextBox x:Name="CreateOp1Box" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,8">
                                        <TextBlock Text="Op2"/>
                                        <TextBox x:Name="CreateOp2Box" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,8">
                                        <TextBlock Text="Op3"/>
                                        <TextBox x:Name="CreateOp3Box" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,8">
                                        <TextBlock Text="Op4"/>
                                        <TextBox x:Name="CreateOp4Box" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,8">
                                        <TextBlock Text="Op5"/>
                                        <TextBox x:Name="CreateOp5Box" Text="0"/>
                                    </StackPanel>
                                </UniformGrid>
                                <Button Grid.Row="6"
                                        Content="Add Object"
                                        Click="AddObject_Click"
                                        HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="6" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Selected Object" FontWeight="SemiBold" Foreground="#111827"/>
                                <TextBlock x:Name="SelectedObjectText"
                                           Grid.Row="1"
                                           Margin="0,4,0,8"
                                           Foreground="#4B5563"
                                           TextWrapping="Wrap"/>
                                <UniformGrid Grid.Row="2" Columns="4">
                                    <StackPanel Margin="0,0,4,6">
                                        <TextBlock Text="SX"/>
                                        <TextBox x:Name="SourceXBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="SY"/>
                                        <TextBox x:Name="SourceYBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="SW"/>
                                        <TextBox x:Name="SourceWidthBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,6">
                                        <TextBlock Text="SH"/>
                                        <TextBox x:Name="SourceHeightBox"/>
                                    </StackPanel>
                                </UniformGrid>
                                <UniformGrid Grid.Row="3" Columns="4">
                                    <StackPanel Margin="0,0,4,8">
                                        <TextBlock Text="DX"/>
                                        <TextBox x:Name="DestXBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,8">
                                        <TextBlock Text="DY"/>
                                        <TextBox x:Name="DestYBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,8">
                                        <TextBlock Text="DW"/>
                                        <TextBox x:Name="DestWidthBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,8">
                                        <TextBlock Text="DH"/>
                                        <TextBox x:Name="DestHeightBox"/>
                                    </StackPanel>
                                </UniformGrid>
                                <Button Grid.Row="4"
                                        Content="Apply Object Geometry"
                                        Click="ApplyObject_Click"
                                        HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Border>

                        <DataGrid x:Name="ObjectsGrid"
                                  Grid.Row="5"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionChanged="ObjectsGrid_SelectionChanged"
                                  PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  CanUserAddRows="False">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="New Object" Click="CreateObjectFromContext_Click"/>
                                    <MenuItem Header="Delete Selected Object" Click="DeleteSelectedObject_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="42"/>
                                <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="105"/>
                                <DataGridTextColumn Header="Line" Binding="{Binding Location}" Width="95"/>
                                <DataGridTextColumn Header="X" Binding="{Binding DestX}" Width="52"/>
                                <DataGridTextColumn Header="Y" Binding="{Binding DestY}" Width="52"/>
                                <DataGridTextColumn Header="W" Binding="{Binding DestWidth}" Width="52"/>
                                <DataGridTextColumn Header="H" Binding="{Binding DestHeight}" Width="52"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                    </ScrollViewer>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="5"
                              HorizontalAlignment="Stretch"
                              Background="#E5E7EB"/>

                <TabControl Grid.Column="2" Margin="10">
                    <TabItem Header="Code">
                        <TextBox x:Name="CodeEditor"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas, Yu Gothic UI, Meiryo, MS Gothic"
                                 FontSize="13"
                                 TextChanged="CodeEditor_TextChanged"
                                 PreviewKeyDown="PreviewCodeEditor_PreviewKeyDown"
                                 LostKeyboardFocus="PreviewCodeEditor_LostKeyboardFocus"/>
                    </TabItem>
                    <TabItem Header="Help">
                        <Grid Background="#FFFFFF">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="380"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBox x:Name="SkinHelpSearchBox"
                                                 MinHeight="28"
                                                 TextChanged="SkinHelpSearchBox_TextChanged"/>
                                        <TextBlock x:Name="SkinHelpPathText"
                                                   Margin="0,4,0,0"
                                                   Foreground="#6B7280"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="10,0,0,0">
                                        <ComboBox x:Name="SkinHelpModeBox"
                                                  Width="128"
                                                  SelectedIndex="0"
                                                  SelectionChanged="SkinHelpModeBox_SelectionChanged"
                                                  Margin="0,0,8,0">
                                            <ComboBoxItem Content="Current Skin" Tag="current"/>
                                            <ComboBoxItem Content="Templates" Tag="templates"/>
                                        </ComboBox>
                                        <Button Content="Insert Template"
                                                Click="InsertSkinHelp_Click"
                                                MinWidth="108"
                                                Margin="0,0,8,0"/>
                                        <TextBlock x:Name="SkinHelpSummaryText"
                                                   VerticalAlignment="Center"
                                                   Foreground="#4B5563"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataGrid x:Name="SkinHelpGrid"
                                      Grid.Row="1"
                                      Grid.Column="0"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="False"
                                      SelectionMode="Single"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      BeginningEdit="SkinHelpGrid_BeginningEdit"
                                      CellEditEnding="SkinHelpGrid_CellEditEnding"
                                      SelectionChanged="SkinHelpGrid_SelectionChanged"
                                      PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="New Object" Click="CreateObjectFromHelpContext_Click"/>
                                        <MenuItem Header="Delete Helper Object" Click="DeleteObjectFromHelpContext_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.CellStyle>
                                    <Style TargetType="{x:Type DataGridCell}">
                                        <Setter Property="ToolTip" Value="{Binding Detail}"/>
                                    </Style>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="58" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="110" IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="Command" Width="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Command}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Detail}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <ComboBox IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=SkinHelpCommandChoices}"
                                                          Text="{Binding Command, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="130" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Fields" Binding="{Binding Arguments, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="CSV" Binding="{Binding RawLine, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Grid.Row="1"
                                    Grid.RowSpan="3"
                                    Grid.Column="1"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1,0,0,0"
                                    Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="쉬운 헬퍼"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"/>
                                    <TextBlock x:Name="SkinHelpEasySummaryText"
                                               Grid.Row="1"
                                               Margin="0,4,0,10"
                                               TextWrapping="Wrap"
                                               Foreground="#4B5563"/>

                                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                                        <TextBlock Text="명령" FontWeight="SemiBold" Foreground="#111827"/>
                                        <ComboBox x:Name="SkinHelpEasyCommandBox"
                                                  Margin="0,4,0,0"
                                                  MinHeight="30"
                                                  IsEditable="True"
                                                  IsTextSearchEnabled="True"
                                                  ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=SkinHelpCommandChoices}"
                                                  SelectionChanged="SkinHelpEasyCommandBox_SelectionChanged"
                                                  LostKeyboardFocus="SkinHelpEasyCommandBox_LostKeyboardFocus"/>
                                    </StackPanel>

                                    <DataGrid x:Name="SkinHelpEasyFieldsGrid"
                                              Grid.Row="3"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal">
                                        <DataGrid.CellStyle>
                                            <Style TargetType="{x:Type DataGridCell}">
                                                <Setter Property="ToolTip" Value="{Binding Hint}"/>
                                            </Style>
                                        </DataGrid.CellStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="42" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="칸" Binding="{Binding Name}" Width="150" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="값" Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <UniformGrid Grid.Row="4" Columns="3" Margin="0,10,0,8">
                                        <Button x:Name="SkinHelpEasyApplyButton"
                                                Content="적용"
                                                MinHeight="30"
                                                Margin="0,0,6,0"
                                                Click="SkinHelpEasyApply_Click"/>
                                        <Button x:Name="SkinHelpEasyInsertButton"
                                                Content="코드에 넣기"
                                                MinHeight="30"
                                                Margin="0,0,6,0"
                                                Click="SkinHelpEasyInsert_Click"/>
                                        <Button x:Name="SkinHelpEasyResetButton"
                                                Content="되돌리기"
                                                MinHeight="30"
                                                Click="SkinHelpEasyReset_Click"/>
                                    </UniformGrid>

                                    <Expander Grid.Row="5" Header="고급 CSV" IsExpanded="False">
                                        <TextBox x:Name="SkinHelpEasyCsvBox"
                                                 IsReadOnly="True"
                                                 Margin="0,6,0,0"
                                                 MinHeight="54"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas, Yu Gothic UI, Meiryo, MS Gothic"
                                                 FontSize="12"/>
                                    </Expander>
                                </Grid>
                            </Border>

                            <Expander x:Name="SkinIfExpander"
                                      Grid.Row="2"
                                      Grid.Column="0"
                                      Header="IF blocks"
                                      IsExpanded="False"
                                      BorderBrush="#E5E7EB"
                                      BorderThickness="0,1,0,0"
                                      Padding="10,6">
                                <DockPanel LastChildFill="True">
                                    <TextBlock x:Name="SkinIfSummaryText"
                                               DockPanel.Dock="Top"
                                               Margin="0,0,0,6"
                                               Foreground="#4B5563"/>
                                    <TreeView x:Name="SkinIfTree"
                                              MaxHeight="190"
                                              SelectedItemChanged="SkinIfTree_SelectedItemChanged">
                                        <TreeView.ItemTemplate>
                                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                <StackPanel Orientation="Horizontal" ToolTip="{Binding Detail}">
                                                    <TextBlock Text="{Binding Header}"
                                                               FontFamily="Consolas, Yu Gothic UI, Meiryo, MS Gothic"/>
                                                    <TextBlock Text="{Binding Summary}"
                                                               Margin="8,0,0,0"
                                                               Foreground="#6B7280"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </HierarchicalDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>
                                </DockPanel>
                            </Expander>

                            <TextBox x:Name="SkinHelpDetailBox"
                                     Grid.Row="3"
                                     Grid.Column="0"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     MinHeight="72"
                                     MaxHeight="140"
                                     BorderBrush="#E5E7EB"
                                     BorderThickness="0,1,0,0"
                                     FontFamily="Consolas, Yu Gothic UI, Meiryo, MS Gothic"
                                     FontSize="13"/>
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="PreviewTab" Header="Preview">
                        <Grid Background="#111827">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#1F2937" BorderBrush="#374151" BorderThickness="0,0,0,1" Padding="10,8">
                                <DockPanel LastChildFill="True">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <TextBlock Text="Time"
                                                   Foreground="#E5E7EB"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <Slider x:Name="PreviewTimeSlider"
                                                Width="260"
                                                Minimum="0"
                                                Maximum="10000"
                                                TickFrequency="500"
                                                IsSnapToTickEnabled="False"
                                                Value="1000"
                                                VerticalAlignment="Center"
                                                ValueChanged="PreviewTimeSlider_ValueChanged"/>
                                        <TextBox x:Name="PreviewTimeBox"
                                                 Width="74"
                                                 Margin="8,0,4,0"
                                                 Text="1000"
                                                 LostFocus="PreviewTimeBox_LostFocus"/>
                                        <TextBlock Text="ms"
                                                   Foreground="#D1D5DB"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <ComboBox x:Name="PreviewModeBox"
                                                  Width="112"
                                                  SelectedIndex="0"
                                                  SelectionChanged="PreviewModeBox_SelectionChanged"
                                                  Margin="0,0,8,0">
                                            <ComboBoxItem Content="Playing" Tag="playing"/>
                                            <ComboBoxItem Content="Ready" Tag="ready"/>
                                            <ComboBoxItem Content="Scene" Tag="scene"/>
                                            <ComboBoxItem Content="All timers" Tag="all"/>
                                        </ComboBox>
                                        <Button Content="Refresh"
                                                Click="RefreshPreview_Click"
                                                MinWidth="82"/>
                                        <TextBlock x:Name="PreviewZoomText"
                                                   Text="Zoom 100%"
                                                   Foreground="#D1D5DB"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="LR2-style simulated frame"
                                               Foreground="#9CA3AF"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"/>
                                </DockPanel>
                            </Border>
                            <Grid Grid.Row="1" Background="#0B1020">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="560"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="420"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="PreviewCodePanel"
                                        Grid.Column="0"
                                        VerticalAlignment="Stretch"
                                        Margin="12"
                                        Background="#EE0F172A"
                                        BorderBrush="#4B5563"
                                        BorderThickness="1"
                                        Padding="10"
                                        Focusable="False">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                            <TextBlock Text="Code / CSV"
                                                       Foreground="#F9FAFB"
                                                       FontWeight="SemiBold"
                                                       DockPanel.Dock="Left"/>
                                            <TextBlock x:Name="PreviewCodeStatusText"
                                                       Foreground="#9CA3AF"
                                                       TextAlignment="Right"/>
                                        </DockPanel>
                                        <TabControl x:Name="PreviewCodeTabs"
                                                    Grid.Row="1"
                                                    SelectionChanged="PreviewCodeTabs_SelectionChanged"
                                                    Background="#111827"
                                                    BorderBrush="#374151"/>
                                        <UniformGrid Grid.Row="2" Columns="2" Margin="0,8,0,0">
                                            <Button Content="Save All"
                                                    Click="Save_Click"
                                                    MinHeight="28"
                                                    Margin="0,0,4,0"/>
                                            <Button Content="Reload Tabs"
                                                    Click="ReloadPreviewCodeTabs_Click"
                                                    MinHeight="28"
                                                    Margin="4,0,0,0"/>
                                        </UniformGrid>
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1" Margin="8,12" ClipToBounds="True">
                                    <ScrollViewer x:Name="PreviewScrollViewer"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto"
                                                  Background="#0B1020"
                                                  Focusable="False"
                                                  SizeChanged="PreviewViewport_SizeChanged"
                                                  PreviewMouseWheel="PreviewScrollViewer_PreviewMouseWheel">
                                        <Grid x:Name="PreviewSurface"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center">
                                            <Grid.LayoutTransform>
                                                <ScaleTransform x:Name="PreviewCanvasScale" ScaleX="1" ScaleY="1"/>
                                            </Grid.LayoutTransform>
                                            <Canvas x:Name="PreviewCanvas"
                                                    Background="#0B1020"
                                                    Focusable="True"
                                                    MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown"
                                                    MouseMove="PreviewCanvas_MouseMove"
                                                    MouseLeftButtonUp="PreviewCanvas_MouseLeftButtonUp"
                                                    MouseRightButtonDown="PreviewCanvas_MouseRightButtonDown"
                                                    KeyDown="PreviewCanvas_KeyDown">
                                                <Canvas.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="New Object Here" Click="CreateObjectAtPreviewContext_Click"/>
                                                        <MenuItem Header="Delete Selected Object" Click="DeleteSelectedObject_Click"/>
                                                    </ContextMenu>
                                                </Canvas.ContextMenu>
                                            </Canvas>
                                        </Grid>
                                    </ScrollViewer>
                                    <TextBlock x:Name="PreviewOverlay"
                                               VerticalAlignment="Top"
                                               HorizontalAlignment="Left"
                                               Margin="12"
                                               Foreground="#E5E7EB"
                                               Background="#99000000"
                                               Padding="8,4"
                                               Focusable="False"
                                               IsHitTestVisible="False"/>
                                </Grid>

                                <Border x:Name="PreviewSelectionPanel"
                                        Grid.Column="2"
                                        VerticalAlignment="Stretch"
                                        Margin="0,12,12,12"
                                        Background="#DD111827"
                                        BorderBrush="#4B5563"
                                        BorderThickness="1"
                                        Padding="10"
                                        Focusable="False">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="96"/>
                                            <RowDefinition Height="126"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="74"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="74"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                            <TextBlock Text="Selection"
                                                       Foreground="#F9FAFB"
                                                       FontWeight="SemiBold"
                                                       DockPanel.Dock="Left"/>
                                            <TextBlock x:Name="PreviewCsvStatusText"
                                                       Foreground="#9CA3AF"
                                                       TextAlignment="Right"/>
                                        </DockPanel>
                                        <Border Grid.Row="1"
                                                Background="#66111827"
                                                BorderBrush="#374151"
                                                BorderThickness="1"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Image x:Name="PreviewSelectionImage"
                                                       Stretch="Uniform"
                                                       SnapsToDevicePixels="True"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                <TextBlock x:Name="PreviewSelectionImageLabel"
                                                           Text="No image selected"
                                                           Foreground="#9CA3AF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"/>
                                            </Grid>
                                        </Border>
                                        <TextBox x:Name="PreviewSelectionBox"
                                                 Grid.Row="2"
                                                 IsReadOnly="True"
                                                 Focusable="False"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 Background="#00111827"
                                                 BorderBrush="#374151"
                                                 Foreground="#E5E7EB"
                                                 FontFamily="Consolas, Yu Gothic UI, Meiryo, MS Gothic"
                                                 FontSize="12"/>
                                        <TextBlock Grid.Row="3"
                                                   Text="SRC CSV"
                                                   Foreground="#F9FAFB"
                                                   FontWeight="SemiBold"
                                                   Margin="0,8,0,4"/>
                                        <TextBox x:Name="PreviewSourceCsvBox"
                                                 Grid.Row="4"
                                                 AcceptsReturn="False"
                                                 TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Disabled"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 Background="#F9FAFB"
                                                 BorderBrush="#4B5563"
                                                 Foreground="#111827"
                                                 FontFamily="Consolas, Yu Gothic UI, Meiryo, MS Gothic"
                                                 FontSize="12"/>
                                        <TextBlock Grid.Row="5"
                                                   Text="DST CSV"
                                                   Foreground="#F9FAFB"
                                                   FontWeight="SemiBold"
                                                   Margin="0,8,0,4"/>
                                        <TextBox x:Name="PreviewDestinationCsvBox"
                                                 Grid.Row="6"
                                                 AcceptsReturn="False"
                                                 TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Disabled"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 Background="#F9FAFB"
                                                 BorderBrush="#4B5563"
                                                 Foreground="#111827"
                                                 FontFamily="Consolas, Yu Gothic UI, Meiryo, MS Gothic"
                                                 FontSize="12"/>
                                        <UniformGrid Grid.Row="7" Columns="2" Margin="0,8,0,0">
                                            <Button x:Name="ApplyPreviewCsvButton"
                                                    Content="Apply CSV"
                                                    Click="ApplyPreviewCsv_Click"
                                                    MinHeight="28"
                                                    Margin="0,0,4,0"/>
                                            <Button x:Name="ResetPreviewCsvButton"
                                                    Content="Reset"
                                                    Click="ResetPreviewCsv_Click"
                                                    MinHeight="28"
                                                    Margin="4,0,0,0"/>
                                        </UniformGrid>
                                    </Grid>
                                </Border>
                            </Grid>                        </Grid>
                    </TabItem>
                    <TabItem Header="Diagnostics">
                        <TextBox x:Name="DiagnosticsBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas, Yu Gothic UI, Meiryo, MS Gothic"
                                 FontSize="13"/>
                    </TabItem>
                </TabControl>
            </Grid>

            <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="0,1,0,0" Padding="10,6">
                <TextBlock x:Name="FooterText" Foreground="#4B5563"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
