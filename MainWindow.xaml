<Window x:Class="SkinEditorNext.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LR2 Skin Editor Next"
        Height="860"
        Width="1320"
        MinHeight="680"
        MinWidth="1060"
        Background="#F3F4F6"
        PreviewKeyDown="Window_PreviewKeyDown">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="New Skin..." Click="NewSkin_Click"/>
                <Separator/>
                <MenuItem Header="Open..." Click="Open_Click"/>
                <MenuItem Header="Save" Click="Save_Click"/>
                <MenuItem Header="Save As..." Click="SaveAs_Click"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="Validate" Click="Validate_Click"/>
                <MenuItem Header="Refresh Preview" Click="RefreshPreview_Click"/>
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="0,0,0,1" Padding="10,8">
                <DockPanel LastChildFill="True">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Content="New" Click="NewSkin_Click" MinWidth="76" Margin="0,0,6,0"/>
                        <Button Content="Open" Click="Open_Click" MinWidth="76" Margin="0,0,6,0"/>
                        <Button Content="Save" Click="Save_Click" MinWidth="76" Margin="0,0,6,0"/>
                        <Button Content="Save As" Click="SaveAs_Click" MinWidth="86" Margin="0,0,14,0"/>
                        <Button Content="Validate" Click="Validate_Click" MinWidth="86" Margin="0,0,6,0"/>
                        <Button Content="Preview" Click="RefreshPreview_Click" MinWidth="86"/>
                    </StackPanel>
                    <TextBlock x:Name="StatusText"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="#374151"/>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="430"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="0,0,1,0" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="File" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock x:Name="FilePathText"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Foreground="#4B5563"/>
                            <TextBlock x:Name="EncodingText"
                                       Margin="0,4,0,12"
                                       Foreground="#6B7280"/>
                        </StackPanel>

                        <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="#RESOLUTION" FontWeight="SemiBold" Foreground="#111827"/>
                                <UniformGrid Grid.Row="1" Columns="2" Margin="0,8,0,8">
                                    <StackPanel Margin="0,0,6,0">
                                        <TextBlock Text="Width" Foreground="#4B5563"/>
                                        <TextBox x:Name="ResolutionWidthBox" MinHeight="28"/>
                                    </StackPanel>
                                    <StackPanel Margin="6,0,0,0">
                                        <TextBlock Text="Height" Foreground="#4B5563"/>
                                        <TextBox x:Name="ResolutionHeightBox" MinHeight="28"/>
                                    </StackPanel>
                                </UniformGrid>
                                <Button Grid.Row="2"
                                        Content="Apply Resolution"
                                        Click="ApplyResolution_Click"
                                        HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="112"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0">
                                    <TextBlock Text="Assets" FontWeight="SemiBold" Foreground="#111827" DockPanel.Dock="Left"/>
                                    <TextBlock x:Name="AssetsSummaryText"
                                               Foreground="#6B7280"
                                               TextAlignment="Right"/>
                                </DockPanel>
                                <ComboBox x:Name="ImageAssetBox"
                                          Grid.Row="1"
                                          DisplayMemberPath="DisplayName"
                                          SelectionChanged="ImageAssetBox_SelectionChanged"
                                          Margin="0,8,0,8"/>
                                <Border Grid.Row="2"
                                        Background="#F9FAFB"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <Image x:Name="AssetPreviewImage"
                                               Stretch="Uniform"
                                               SnapsToDevicePixels="True"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                        <TextBlock x:Name="AssetPreviewLabel"
                                                   Text="No asset selected"
                                                   Foreground="#6B7280"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"/>
                                    </Grid>
                                </Border>
                                <TextBlock x:Name="AssetPreviewInfoText"
                                           Grid.Row="3"
                                           Margin="0,0,0,8"
                                           Foreground="#4B5563"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <Button Grid.Row="4"
                                        Content="Add Image..."
                                        Click="AddImage_Click"
                                        HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Create Object" FontWeight="SemiBold" Foreground="#111827"/>
                                <UniformGrid Grid.Row="1" Columns="2" Margin="0,8,0,8">
                                    <StackPanel Margin="0,0,6,0">
                                        <TextBlock Text="Kind" Foreground="#4B5563"/>
                                        <ComboBox x:Name="CreateKindBox" SelectedIndex="0">
                                            <ComboBoxItem Content="Image" Tag="image"/>
                                            <ComboBoxItem Content="Text" Tag="text"/>
                                            <ComboBoxItem Content="Number" Tag="number"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Margin="6,0,0,0">
                                        <TextBlock Text="Text Kind / Number Op1" Foreground="#4B5563"/>
                                        <TextBox x:Name="CreateValueBox" Text="11"/>
                                    </StackPanel>
                                </UniformGrid>
                                <UniformGrid Grid.Row="2" Columns="4">
                                    <StackPanel Margin="0,0,4,6">
                                        <TextBlock Text="X"/>
                                        <TextBox x:Name="CreateXBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="Y"/>
                                        <TextBox x:Name="CreateYBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="W"/>
                                        <TextBox x:Name="CreateWidthBox" Text="320"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,6">
                                        <TextBlock Text="H"/>
                                        <TextBox x:Name="CreateHeightBox" Text="180"/>
                                    </StackPanel>
                                </UniformGrid>
                                <UniformGrid Grid.Row="3" Columns="5">
                                    <StackPanel Margin="0,0,4,6">
                                        <TextBlock Text="Time"/>
                                        <TextBox x:Name="CreateTimeBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="Alpha"/>
                                        <TextBox x:Name="CreateAlphaBox" Text="255"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="R"/>
                                        <TextBox x:Name="CreateRedBox" Text="255"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="G"/>
                                        <TextBox x:Name="CreateGreenBox" Text="255"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,6">
                                        <TextBlock Text="B"/>
                                        <TextBox x:Name="CreateBlueBox" Text="255"/>
                                    </StackPanel>
                                </UniformGrid>
                                <UniformGrid Grid.Row="4" Columns="5">
                                    <StackPanel Margin="0,0,4,6">
                                        <TextBlock Text="Acc"/>
                                        <TextBox x:Name="CreateAccBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="Blend"/>
                                        <TextBox x:Name="CreateBlendBox" Text="1"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="Filter"/>
                                        <TextBox x:Name="CreateFilterBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="Angle"/>
                                        <TextBox x:Name="CreateAngleBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,6">
                                        <TextBlock Text="Center"/>
                                        <TextBox x:Name="CreateCenterBox" Text="0"/>
                                    </StackPanel>
                                </UniformGrid>
                                <UniformGrid Grid.Row="5" Columns="7">
                                    <StackPanel Margin="0,0,4,8">
                                        <TextBlock Text="Loop"/>
                                        <TextBox x:Name="CreateLoopBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,8">
                                        <TextBlock Text="Timer"/>
                                        <TextBox x:Name="CreateTimerBox" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,8">
                                        <TextBlock Text="Op1"/>
                                        <TextBox x:Name="CreateOp1Box" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,8">
                                        <TextBlock Text="Op2"/>
                                        <TextBox x:Name="CreateOp2Box" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,8">
                                        <TextBlock Text="Op3"/>
                                        <TextBox x:Name="CreateOp3Box" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,8">
                                        <TextBlock Text="Op4"/>
                                        <TextBox x:Name="CreateOp4Box" Text="0"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,8">
                                        <TextBlock Text="Op5"/>
                                        <TextBox x:Name="CreateOp5Box" Text="0"/>
                                    </StackPanel>
                                </UniformGrid>
                                <Button Grid.Row="6"
                                        Content="Add Object"
                                        Click="AddObject_Click"
                                        HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4" BorderBrush="#E5E7EB" BorderThickness="1" Padding="10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Selected Object" FontWeight="SemiBold" Foreground="#111827"/>
                                <TextBlock x:Name="SelectedObjectText"
                                           Grid.Row="1"
                                           Margin="0,4,0,8"
                                           Foreground="#4B5563"
                                           TextWrapping="Wrap"/>
                                <UniformGrid Grid.Row="2" Columns="4">
                                    <StackPanel Margin="0,0,4,6">
                                        <TextBlock Text="SX"/>
                                        <TextBox x:Name="SourceXBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="SY"/>
                                        <TextBox x:Name="SourceYBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,6">
                                        <TextBlock Text="SW"/>
                                        <TextBox x:Name="SourceWidthBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,6">
                                        <TextBlock Text="SH"/>
                                        <TextBox x:Name="SourceHeightBox"/>
                                    </StackPanel>
                                </UniformGrid>
                                <UniformGrid Grid.Row="3" Columns="4">
                                    <StackPanel Margin="0,0,4,8">
                                        <TextBlock Text="DX"/>
                                        <TextBox x:Name="DestXBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,8">
                                        <TextBlock Text="DY"/>
                                        <TextBox x:Name="DestYBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,4,8">
                                        <TextBlock Text="DW"/>
                                        <TextBox x:Name="DestWidthBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,8">
                                        <TextBlock Text="DH"/>
                                        <TextBox x:Name="DestHeightBox"/>
                                    </StackPanel>
                                </UniformGrid>
                                <Button Grid.Row="4"
                                        Content="Apply Object Geometry"
                                        Click="ApplyObject_Click"
                                        HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Border>

                        <DataGrid x:Name="ObjectsGrid"
                                  Grid.Row="5"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionChanged="ObjectsGrid_SelectionChanged"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="42"/>
                                <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="105"/>
                                <DataGridTextColumn Header="Line" Binding="{Binding Location}" Width="95"/>
                                <DataGridTextColumn Header="X" Binding="{Binding DestX}" Width="52"/>
                                <DataGridTextColumn Header="Y" Binding="{Binding DestY}" Width="52"/>
                                <DataGridTextColumn Header="W" Binding="{Binding DestWidth}" Width="52"/>
                                <DataGridTextColumn Header="H" Binding="{Binding DestHeight}" Width="52"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="5"
                              HorizontalAlignment="Stretch"
                              Background="#E5E7EB"/>

                <TabControl Grid.Column="2" Margin="10">
                    <TabItem Header="Code">
                        <TextBox x:Name="CodeEditor"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 TextChanged="CodeEditor_TextChanged"/>
                    </TabItem>
                    <TabItem Header="Help">
                        <Grid Background="#FFFFFF">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBox x:Name="SkinHelpSearchBox"
                                                 MinHeight="28"
                                                 TextChanged="SkinHelpSearchBox_TextChanged"/>
                                        <TextBlock x:Name="SkinHelpPathText"
                                                   Margin="0,4,0,0"
                                                   Foreground="#6B7280"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="10,0,0,0">
                                        <ComboBox x:Name="SkinHelpModeBox"
                                                  Width="128"
                                                  SelectedIndex="0"
                                                  SelectionChanged="SkinHelpModeBox_SelectionChanged"
                                                  Margin="0,0,8,0">
                                            <ComboBoxItem Content="Current Skin" Tag="current"/>
                                            <ComboBoxItem Content="Templates" Tag="templates"/>
                                        </ComboBox>
                                        <Button Content="Insert Template"
                                                Click="InsertSkinHelp_Click"
                                                MinWidth="108"
                                                Margin="0,0,8,0"/>
                                        <TextBlock x:Name="SkinHelpSummaryText"
                                                   VerticalAlignment="Center"
                                                   Foreground="#4B5563"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataGrid x:Name="SkinHelpGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      CanUserAddRows="False"
                                      SelectionChanged="SkinHelpGrid_SelectionChanged"
                                      MouseDoubleClick="SkinHelpGrid_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="130"/>
                                    <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="62"/>
                                    <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="120"/>
                                    <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="150"/>
                                    <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="150"/>
                                    <DataGridTextColumn Header="Fields" Binding="{Binding Arguments}" Width="2*"/>
                                    <DataGridTextColumn Header="CSV" Binding="{Binding RawLine}" Width="2*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBox x:Name="SkinHelpDetailBox"
                                     Grid.Row="2"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     MinHeight="72"
                                     MaxHeight="140"
                                     BorderBrush="#E5E7EB"
                                     BorderThickness="0,1,0,0"
                                     FontFamily="Consolas"
                                     FontSize="13"/>
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="PreviewTab" Header="Preview">
                        <Grid Background="#111827">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#1F2937" BorderBrush="#374151" BorderThickness="0,0,0,1" Padding="10,8">
                                <DockPanel LastChildFill="True">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <TextBlock Text="Time"
                                                   Foreground="#E5E7EB"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <Slider x:Name="PreviewTimeSlider"
                                                Width="260"
                                                Minimum="0"
                                                Maximum="10000"
                                                TickFrequency="500"
                                                IsSnapToTickEnabled="False"
                                                Value="1000"
                                                VerticalAlignment="Center"
                                                ValueChanged="PreviewTimeSlider_ValueChanged"/>
                                        <TextBox x:Name="PreviewTimeBox"
                                                 Width="74"
                                                 Margin="8,0,4,0"
                                                 Text="1000"
                                                 LostFocus="PreviewTimeBox_LostFocus"/>
                                        <TextBlock Text="ms"
                                                   Foreground="#D1D5DB"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <ComboBox x:Name="PreviewModeBox"
                                                  Width="112"
                                                  SelectedIndex="0"
                                                  SelectionChanged="PreviewModeBox_SelectionChanged"
                                                  Margin="0,0,8,0">
                                            <ComboBoxItem Content="Playing" Tag="playing"/>
                                            <ComboBoxItem Content="Ready" Tag="ready"/>
                                            <ComboBoxItem Content="Scene" Tag="scene"/>
                                            <ComboBoxItem Content="All timers" Tag="all"/>
                                        </ComboBox>
                                        <Button Content="Refresh"
                                                Click="RefreshPreview_Click"
                                                MinWidth="82"/>
                                    </StackPanel>
                                    <TextBlock Text="LR2-style simulated frame"
                                               Foreground="#9CA3AF"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right"/>
                                </DockPanel>
                            </Border>
                            <Grid Grid.Row="1">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                    <Canvas x:Name="PreviewCanvas"
                                            Background="#0B1020"
                                            Focusable="True"
                                            MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown"
                                            MouseMove="PreviewCanvas_MouseMove"
                                            MouseLeftButtonUp="PreviewCanvas_MouseLeftButtonUp"
                                            KeyDown="PreviewCanvas_KeyDown"/>
                                </ScrollViewer>
                                <TextBlock x:Name="PreviewOverlay"
                                           VerticalAlignment="Top"
                                           HorizontalAlignment="Left"
                                           Margin="12"
                                           Foreground="#E5E7EB"
                                           Background="#99000000"
                                           Padding="8,4"
                                           Focusable="False"
                                           IsHitTestVisible="False"/>
                                <Border x:Name="PreviewSelectionPanel"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Stretch"
                                        Width="340"
                                        Margin="0,12,12,12"
                                        Background="#DD111827"
                                        BorderBrush="#4B5563"
                                        BorderThickness="1"
                                        Padding="10"
                                        Focusable="False"
                                        IsHitTestVisible="False">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="104"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Selection"
                                                   Foreground="#F9FAFB"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <Border Grid.Row="1"
                                                Background="#66111827"
                                                BorderBrush="#374151"
                                                BorderThickness="1"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Image x:Name="PreviewSelectionImage"
                                                       Stretch="Uniform"
                                                       SnapsToDevicePixels="True"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                <TextBlock x:Name="PreviewSelectionImageLabel"
                                                           Text="No image selected"
                                                           Foreground="#9CA3AF"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"/>
                                            </Grid>
                                        </Border>
                                        <TextBox x:Name="PreviewSelectionBox"
                                                 Grid.Row="2"
                                                 IsReadOnly="True"
                                                 Focusable="False"
                                                 IsHitTestVisible="False"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 Background="#00111827"
                                                 BorderBrush="#374151"
                                                 Foreground="#E5E7EB"
                                                 FontFamily="Consolas"
                                                 FontSize="12"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Diagnostics">
                        <TextBox x:Name="DiagnosticsBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="13"/>
                    </TabItem>
                </TabControl>
            </Grid>

            <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="0,1,0,0" Padding="10,6">
                <TextBlock x:Name="FooterText" Foreground="#4B5563"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
